# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/

# Node / Next.js
node_modules/
.next/
out/

# Env / secrets — NEVER commit
.env
.env.local
.env*.local

# Private working notes — NEVER commit (this repo is public)
CLAUDE.local.md
CLAUDE_LOCAL.md
.claude/SESSION_STATE.md
.claude/settings.local.json

# Bench — raw roast dumps carry the FULL roast text (employer mentions, etc.);
# the baseline_quality.json (scores only) IS committed, the raw text is NOT.
bench/.raw_roasts*.jsonl
bench/.roasts_review.md
bench/.roasts_review.html

# RAG store — runtime artifacts (HDF5 backend + lock file), per-process state.
# Materialized by fi_runner.rag_store on first ingest; never committed.
fi_rag_store.h5
fi_rag_store.h5.lock

# Local verification screenshots (chrome-devtools runs during dev).
.tmp-screenshots/

# Misc
*.log
.DS_Store
