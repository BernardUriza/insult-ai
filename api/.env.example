# ── Backend selection ───────────────────────────────────────────────
INSULT_AI_BACKEND=claude          # "claude" or "codex"
# INSULT_AI_MODEL=claude-sonnet-4-5   # optional override

# ── Claude Code (Max) — used when INSULT_AI_BACKEND=claude ───────────
CLAUDE_CODE_OAUTH_TOKEN=          # your Claude Max OAuth token (materialized by entrypoint.sh)

# ── Codex (Azure OpenAI, API-motor) — used when INSULT_AI_BACKEND=codex ─
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/openai/v1

# ── API gating (Bright Data credit + Claude tokens cost real money) ─
# Shared X-API-Key matched against this env var. UNSET in local dev = the
# API fail-opens with a loud WARN log; SET in production = clients without
# the header get 401. Pair this with the per-IP rate limit (SlowAPI) wired
# in app.py. The web bundle picks it up via NEXT_PUBLIC_API_KEY at build
# time (so the same secret is BOTH the API gate AND the front's outbound
# header). NOT a real secret — it ends up in the JS bundle a user can
# inspect; it's a casual-crawler gate.
INSULT_AI_API_KEY=                # any random string; rotate by changing both env + SWA build var

# ── Bright Data MCP (REQUIRED by the hackathon) ─────────────────────
API_TOKEN=                        # Bright Data API token (read by @brightdata/mcp)
# Pro mode unlocks the Scraping Browser (renders JS) + structured web_data
# scrapers (LinkedIn/GitHub/...). Costs MORE credit than basic scrape. Inherited
# by the MCP subprocess via env_passthrough.
PRO_MODE=true

# ── RAG store (the agent's document corpus, via fi-core rag_store MCP) ──
# Two swappable backends — same protocol, change one env var:
#   - hdf5     (default) — single file on disk. ZERO infra; perfect for local
#                dev / the bench. NOT safe in Azure Container Apps because the
#                container filesystem is EPHEMERAL — any restart drops the
#                ingested corpus. Use this in local-dev and the offline bench.
#   - pgvector            — Postgres + the `vector` extension. Persistent
#                across restarts, multi-writer safe (multiple API replicas
#                can ingest into the same store), supports relational
#                filters mixed with vector search. The DEPLOY path.
# FI_RAG_BACKEND=hdf5
# FI_RAG_STORE_PATH=fi_rag_store.h5   # only when BACKEND=hdf5

# When FI_RAG_BACKEND=pgvector — point at Postgres 14+ with the `vector`
# extension installed. Local dev: `infra/docker-compose.dev.yml` brings up
# pgvector/pgvector:pg16 on 5432; the DSN below works as-is against it.
# Azure: `az postgres flexible-server create … --extensions VECTOR`; pass the
# Container App the resulting DSN as a secret.
# FI_RAG_BACKEND=pgvector
# FI_RAG_PGVECTOR_DSN=postgresql://insultai:insultai@127.0.0.1:5433/insultai
# FI_RAG_EMBED_DIM=256                # MUST match the embedder's dim — see below

# Embedder — converts the agent's query text into the vector that pgvector
# searches. Three options, all swappable via env:
#   - hashing               (default) — deterministic hash, dim=256. Zero
#                              cost, zero latency, NO semantic similarity
#                              (it's a keyword-ish proxy). Fine for the
#                              hackathon demo. STARTING POINT.
#   - azure                 — Azure OpenAI text-embedding-3-small (dim=1536).
#                              Real semantic embeddings. Costs tokens per
#                              ingest AND per agent query. Bumping to this
#                              REQUIRES re-ingesting the corpus (schema
#                              EMBED_DIM 256→1536 = different vector column).
#   - sentence_transformers — local model in the container; ~500MB image
#                              size. No API spend after the model download.
# FI_RAG_EMBEDDER=hashing
# FI_RAG_AZURE_DEPLOYMENT=             # only when EMBEDDER=azure (the deployment name)
# FI_RAG_ST_MODEL=                     # only when EMBEDDER=sentence_transformers

# ── Psychology corpus (clinical mode default) — Slice 3 ────────────────
# When ENABLED=1 AND mode is "clinical" AND the user did not supply their
# own corpus_id on the request, the runner falls back to the curated
# public-knowledge corpus identified by CORPUS_ID below. The corpus must
# already be ingested in whatever FI_RAG_BACKEND is configured (run:
# `python bench/ingest_psychology_corpus.py --commit` once per environment).
#
# Default is OFF: with ENABLED=0 or unset, clinical mode is bit-identical
# to pre-Slice-3 behavior. roast and brief modes are NEVER affected.
#
# Failure mode: if ENABLED=1 but the corpus has zero documents (or the
# store is unreachable), app.py's startup probe logs a warning and resets
# the env var to "0" in-process. Clinical mode continues without RAG.
# INSULT_AI_PSYCH_CORPUS_ENABLED=0
# INSULT_AI_PSYCH_CORPUS_ID=psych_public_v1
